# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="HCIP Ingestion Pipeline"
ENVIRONMENT=development
DEBUG=false

# ── AWS S3 ───────────────────────────────────────────────────────────────────
# Get these from: AWS Console → IAM → Users → your user → Security credentials
# See CREDENTIALS_SETUP.md § AWS S3 for exact steps
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=hcip-documents

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Local Docker (default) — no API key required
# Run:  docker-compose up -d qdrant
# UI:   http://localhost:6333/dashboard
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Neo4j ────────────────────────────────────────────────────────────────────
# Local Docker (default) — password matches docker-compose.yml
# Run:  docker-compose up -d neo4j
# UI:   http://localhost:7474  (login: neo4j / hcip_password)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hcip_password

# ── Redis ────────────────────────────────────────────────────────────────────
# Local Docker — no password required in dev
# Run:  docker-compose up -d redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Embedding ────────────────────────────────────────────────────────────────
TEXT_EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# See CREDENTIALS_SETUP.md § OpenAI for exact steps
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini

# ── Elasticsearch ────────────────────────────────────────────────────────────
# Local Docker — run: docker-compose up -d elasticsearch
# UI: http://localhost:9200
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_CHUNK_INDEX=hcip_chunks

# ── PubMed / NCBI E-utilities ─────────────────────────────────────────────────
# Optional — get from: https://www.ncbi.nlm.nih.gov/account/
# Without key: 3 req/s  |  With key: 10 req/s
PUBMED_API_KEY=
PUBMED_MAX_RESULTS=5

# ── Query Cache (4-Layer) ─────────────────────────────────────────────────────
# L1 exact match TTL + L2 semantic TTL (seconds)
CACHE_EXACT_TTL_SECONDS=3600
CACHE_SEMANTIC_TTL_SECONDS=3600
# L2 cosine similarity cut-off (0-1); queries above this threshold share a cached response
CACHE_SEMANTIC_THRESHOLD=0.95
# L3 retrieval results TTL (seconds)
CACHE_RETRIEVAL_TTL_SECONDS=1800
# Qdrant collection used to store past query embeddings for semantic similarity lookup
QDRANT_QUERY_CACHE_COLLECTION=hcip_query_cache

# ── Processing ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
OCR_CONFIDENCE_THRESHOLD=0.70
METADATA_COMPLETENESS_THRESHOLD=0.95
CHUNK_QUALITY_THRESHOLD=0.90
INDEX_READINESS_THRESHOLD=0.85

# ── API Auth ─────────────────────────────────────────────────────────────────
# Format: ["rawkey:org_id:role"] — add as many entries as needed.
# Generate a key yourself, e.g.: python -c "import secrets; print('sk-hcip-' + secrets.token_urlsafe(24))"
API_KEYS=["your_generated_key:org-dev:physician"]

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_generated_jwt_secret
JWT_ALGORITHM=HS256

# CORS — for development keep as-is; in production use your actual domain
CORS_ORIGINS=["*"]

# Rate limiting (requests per minute per API key / JWT user)
RATE_LIMIT_PER_MINUTE=60

# ── Observability ────────────────────────────────────────────────────────────
# OpenTelemetry → Grafana Tempo (local Docker)
# After running docker-compose up -d, Tempo listens on port 4318
OTEL_ENDPOINT=http://localhost:4318/v1/traces

# Langfuse — LLM call tracing (cost, tokens, latency per query)
# Free tier: https://cloud.langfuse.com → New project → Settings → API Keys
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
