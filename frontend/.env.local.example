# HCIP Frontend Environment Variables
# Copy to .env.local and fill in your values.

# FastAPI backend URL (server-side only — never expose to browser)
HCIP_API_URL=http://localhost:8000

# API key for backend auth — just the raw key portion (before the first ":")
# of one of the API_KEYS entries in the backend .env, e.g. if the backend has
# API_KEYS=["sk-dev-key:org-dev:physician"], use HCIP_API_KEY=sk-dev-key
HCIP_API_KEY=sk-dev-key

# Default knowledge base shown in the query form
NEXT_PUBLIC_DEFAULT_KB_ID=kb-clinical-2024
